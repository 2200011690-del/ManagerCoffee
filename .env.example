# Client Environment Variables

# The backend API URL. For production, set this to the deployed backend URL.
# Local development default: http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api

# The backend Socket.io URL.
# Local development default: http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# VietQR configurations (for generating QR codes)
VITE_BANK_ID=MB
VITE_ACCOUNT_NO=123456789
VITE_ACCOUNT_NAME="CAFE MANAGER"
