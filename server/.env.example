# Server Environment Variables
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Example with Supabase:
# DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
DATABASE_URL="postgresql://user:password@localhost:5432/managercoffee?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/managercoffee?schema=public"

# Required in production. Use a long random value and never commit the real secret.
JWT_SECRET="replace-with-a-long-random-secret"
JSON_BODY_LIMIT=5mb

# Optional payment webhook hardening. Configure the same secret in your payment provider.
PAYMENT_WEBHOOK_SECRET="replace-with-payment-webhook-secret"

# Optional e-invoice provider integration.
EINVOICE_PROVIDER=""
EINVOICE_API_URL=""
EINVOICE_API_KEY=""

# Optional delivery/order channel integrations.
GRABFOOD_API_URL=""
GRABFOOD_API_KEY=""
SHOPEEFOOD_API_URL=""
SHOPEEFOOD_API_KEY=""
WEB_ORDER_SECRET=""
