# Server Environment Variables
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Example with Supabase:
# DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
DATABASE_URL="postgresql://user:password@localhost:5432/managercoffee?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/managercoffee?schema=public"

# Required in production. Use a long random value and never commit the real secret.
JWT_SECRET="replace-with-a-long-random-secret"
INTEGRATION_SECRET_KEY="replace-with-a-separate-long-random-secret"
JSON_BODY_LIMIT=5mb

# Optional platform fallback only. Prefer configuring each store in the Integrations UI.
PAYMENT_WEBHOOK_SECRET="replace-with-payment-webhook-secret"
