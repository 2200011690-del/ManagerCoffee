datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Store {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // e.g. espresso-lab
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users      User[]
  products   Product[]
  tables     Table[]
  orders     Order[]
  customers  Customer[]
  vouchers   Voucher[]
  inventories Inventory[]
  suppliers   Supplier[]
  transactions StockTransaction[]
  attendances Attendance[]
  cashShifts  CashShift[]
}

model User {
  id      String  @id @default(cuid())
  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  pin     String  
  name    String
  role    String  // "admin" or "staff"
  orders  Order[]
  attendances Attendance[]
  cashShifts  CashShift[]

  @@unique([storeId, pin])
}

model Product {
  id          String  @id @default(cuid())
  storeId     String
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  price       Float
  category    String
  description String?
  image       String?
  popular     Boolean @default(false)
  prepTime    String? @default("5 phút")
  hidden      Boolean @default(false)
  recipes     RecipeItem[]
}

model Table {
  id            String  @id @default(cuid())
  storeId       String
  store         Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name          String
  zone          String
  capacity      Int
  status        String  @default("available") // "available", "occupied", "dirty"
  occupiedSince String?
}

model Order {
  id             String      @id @default(cuid())
  storeId        String
  store          Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderNumber    String      
  tableId        String?
  tableName      String
  subtotal       Float
  vatAmount      Float
  total          Float
  paymentMethod  String      // "cash" or "card"
  status         String      @default("paid") // "pending", "paid", "cancelled"
  time           String
  date           String
  timestamp      DateTime    @default(now())
  items          OrderItem[]

  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  voucherCode    String?
  discountAmount Float?      @default(0)
  employeeId     String?
  employee       User?       @relation(fields: [employeeId], references: [id])

  @@unique([storeId, orderNumber])
}

model OrderItem {
  id       String  @id @default(cuid())
  orderId  String
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name     String
  price    Float
  qty      Int
  sugar    String?
  ice      String?
  note     String?
}

model Inventory {
  id       String  @id @default(cuid())
  storeId  String
  store    Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name     String
  unit     String
  qty      Float
  minQty   Float
  icon     String?

  recipes      RecipeItem[]
  transactions StockTransaction[]
}

model RecipeItem {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  qty         Float

  @@unique([productId, inventoryId])
}

model Supplier {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  
  transactions StockTransaction[]
}

model StockTransaction {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  type        String    // "IMPORT", "EXPORT", "ADJUST", "SALE"
  qtyChange   Float
  balance     Float
  cost        Float?
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  note        String?
  createdAt   DateTime  @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  phone     String   
  points    Int      @default(0)
  tier      String   @default("SILVER") // SILVER, GOLD, DIAMOND
  createdAt DateTime @default(now())
  orders    Order[]

  @@unique([storeId, phone])
}

model Voucher {
  id            String    @id @default(cuid())
  storeId       String
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code          String    
  type          String    // PERCENT, FIXED
  value         Float
  minOrderValue Float     @default(0)
  maxDiscount   Float?
  expiryDate    DateTime?
  isActive      Boolean   @default(true)

  @@unique([storeId, code])
}

model Attendance {
  id         String    @id @default(cuid())
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn    DateTime  @default(now())
  clockOut   DateTime?
  date       String    // YYYY-MM-DD
  totalHours Float?
}

model CashShift {
  id           String    @id @default(cuid())
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  openingCash  Float
  cashSales    Float     @default(0)
  expectedCash Float
  actualCash   Float?
  discrepancy  Float?
  notes        String?
  status       String    @default("open") // "open", "closed"
}
